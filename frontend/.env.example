# ── Backend URL ────────────────────────────────────────────────────────────────
# Points the frontend at the FastAPI server.
# In local dev the Next.js proxy rewrites /backend/* → http://localhost:8000,
# so you don't need this locally unless you change the backend port.
NEXT_PUBLIC_API_URL=https://savorymind-api.onrender.com
BACKEND_URL=https://savorymind-api.onrender.com

# ── NextAuth ───────────────────────────────────────────────────────────────────
# REQUIRED — must be set in production even if no social providers are used.
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-a-random-32-byte-base64-string

# The canonical public URL of this Next.js app (no trailing slash).
NEXTAUTH_URL=https://your-app.vercel.app

# ── Social login secret ────────────────────────────────────────────────────────
# Must match SOCIAL_LOGIN_SECRET on the backend (Render generates it — copy it here).
SOCIAL_LOGIN_SECRET=copy-from-render-dashboard

# ── Optional social OAuth providers ───────────────────────────────────────────
# Providers whose vars are absent are simply not shown on the login page.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_ID=
# GITHUB_SECRET=
# FACEBOOK_CLIENT_ID=
# FACEBOOK_CLIENT_SECRET=
# AZURE_AD_CLIENT_ID=
# AZURE_AD_CLIENT_SECRET=
# AZURE_AD_TENANT_ID=
# APPLE_ID=
# APPLE_SECRET=
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=
# TWITTER_CLIENT_ID=
# TWITTER_CLIENT_SECRET=
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=
