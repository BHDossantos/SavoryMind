DATABASE_URL=sqlite:///./availablenow.db
JWT_SECRET=change-me-in-prod
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
CORS_ORIGINS=http://localhost:3001,http://localhost:3000
FRONTEND_URL=http://localhost:3001
# Leave STRIPE_SECRET_KEY empty to run in stub mode (no real Stripe calls).
# In stub mode, deposits skip Stripe entirely and complete instantly.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PENDING_PAYMENT_TTL_MINUTES=15

# Leave RESEND_API_KEY empty to run notifications in stub mode
# (notifications get persisted + logged, no real email sent).
RESEND_API_KEY=
NOTIFICATIONS_FROM_EMAIL=noreply@availablenow.app
NOTIFICATIONS_FROM_NAME=AvailableNow
NOTIFICATIONS_TICK_SECONDS=60
