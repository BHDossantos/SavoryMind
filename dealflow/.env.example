# Database — required for the API.
# For local dev use the docker-compose Postgres on port 5433:
DATABASE_URL=postgres://dealflow:dealflow@localhost:5433/dealflow

# Auth.js session secret — required at runtime.
# Generate one with: openssl rand -base64 32
AUTH_SECRET=replace-me-with-a-32-byte-base64-secret

# Required only for the AI deal analysis feature (/api/ai-analysis).
# Without it, the rest of the app works fine — the "Generate AI analysis"
# button on the deal page will show a 503 with a helpful message.
ANTHROPIC_API_KEY=sk-ant-...
