AUTH_SECRET=change-me-in-production-min-32-chars-long
ADMIN_EMAIL=admin@autobook.local
ADMIN_PASSWORD=admin1234

# Notifications — leave RESEND_API_KEY unset to log emails to the dev console.
# RESEND_API_KEY=re_xxx
# NOTIFICATION_FROM=AutoBook <hello@yourdomain.com>

# AI parsing — when set, the booking form shows a "Parse with AI" button that
# extracts structured fields (category, date, party size, vibe…) from the user's
# free-text request via Claude. Both vars are required to enable the feature:
# the server reads ANTHROPIC_API_KEY, the client reads NEXT_PUBLIC_AI_PARSE.
# ANTHROPIC_API_KEY=sk-ant-xxx
# NEXT_PUBLIC_AI_PARSE=1
