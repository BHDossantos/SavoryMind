# ---- App ----
NODE_ENV=development
APP_NAME=FitNow
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# ---- Database ----
POSTGRES_USER=fitnow
POSTGRES_PASSWORD=fitnow
POSTGRES_DB=fitnow
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://fitnow:fitnow@localhost:5432/fitnow

# ---- Auth ----
# Pick one provider; leave the other blank.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

JWT_SECRET=replace-me

# ---- Payments (Stripe) ----
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
PLATFORM_FEE_BPS=1500   # 15%

# ---- Maps ----
GOOGLE_MAPS_API_KEY=

# ---- Email ----
RESEND_API_KEY=
SENDGRID_API_KEY=
EMAIL_FROM=no-reply@fitnow.app

# ---- Observability (optional) ----
SENTRY_DSN=
LOG_LEVEL=info
