# ── Database ───────────────────────────────────────────────────────────────────
# Railway auto-sets DATABASE_URL when you add the PostgreSQL plugin.
# For local dev, SQLite is used by default (no change needed).
DATABASE_URL=postgresql+psycopg2://user:password@host:5432/savorymind

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-64-char-random-hex-string

# Internal secret used to authorize the social login endpoint (NextAuth → API).
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SOCIAL_LOGIN_SECRET=replace-with-a-64-char-random-hex-string

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated or JSON list — must include your Vercel domain
CORS_ORIGINS=["https://savorymind.net","https://www.savorymind.net","https://app.savorymind.net"]

# ── App ───────────────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_DAYS=30
