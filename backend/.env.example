# ── Database ───────────────────────────────────────────────────────────────────
# Production: Cloud SQL via the Unix socket mounted by Cloud Run (set automatically
# by the deploy workflow — you don't need to set this in production).
# Local dev: omit DATABASE_URL entirely to fall back to ./savorymind.db (SQLite).
# DATABASE_URL=postgresql+psycopg2://postgres:password@/savorymind?host=/cloudsql/savorymind:europe-west1:savorymind-db

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-64-char-random-hex-string

# Internal secret used to authorize the social login endpoint (NextAuth → API).
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SOCIAL_LOGIN_SECRET=replace-with-a-64-char-random-hex-string

# ── App ───────────────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_DAYS=30

# ── AI ────────────────────────────────────────────────────────────────────────
# Required for the assistant. Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Required for password reset + transactional emails. https://resend.com/api-keys
# Leave blank in local dev — email sends will be logged instead of dispatched.
RESEND_API_KEY=
# The verified sender address. Must be on a domain verified in your Resend account.
RESEND_FROM_EMAIL=noreply@savorymind.net

# ── Error tracking (Sentry) ──────────────────────────────────────────────────
# Optional — leave blank to disable Sentry entirely.
# Get a DSN at https://sentry.io/ → Project Settings → Client Keys (DSN)
SENTRY_DSN=
# "production", "staging", or "development". Used to tag errors in Sentry.
SENTRY_ENVIRONMENT=development
