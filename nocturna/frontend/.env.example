NEXT_PUBLIC_API_URL=http://localhost:8001

# Optional: enables interactive Mapbox maps on plan + venue pages.
# If empty, an SVG schematic fallback renders instead.
NEXT_PUBLIC_MAPBOX_TOKEN=

# Optional: enables PostHog product analytics (page views, planner_submitted,
# plan_generated, plan_booked, plan_shared, user identify on login).
# If empty, the app sends no events.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
